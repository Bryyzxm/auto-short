# =============================================================================
# AI YouTube to Shorts Segmenter - Environment Configuration
# =============================================================================

# Frontend Configuration
VITE_GEMINI_API_KEY=

# Basic Server Configuration
PORT=3001

# =============================================================================
# TRANSCRIPT ENHANCEMENT FEATURES
# =============================================================================

# yt-dlp Configuration (PRIMARY TRANSCRIPT METHOD)
# yt-dlp is now the PRIMARY and most reliable method for transcript extraction
# The system will automatically detect yt-dlp installation
# Supported installations:
# 1. Binary: yt-dlp (recommended)
# 2. Python module: python -m yt_dlp or python3 -m yt_dlp
# Install: pip install yt-dlp OR download binary from https://github.com/yt-dlp/yt-dlp

# YouTube Data API v3 (SECONDARY FALLBACK)
# Get your API key from: https://console.cloud.google.com/apis/credentials
# Enable YouTube Data API v3 in your Google Cloud project
# Quota: 10,000 units/day (free tier)
# Note: This is now a fallback method, yt-dlp is prioritized
YOUTUBE_API_KEY=your_youtube_api_key_here

# YouTube Cookies (RECOMMENDED for bypassing restrictions)
# Option 1: File path to Netscape cookie format
# YOUTUBE_COOKIES=/path/to/youtube_cookies.txt
# Option 2: URL to cookie file
# YOUTUBE_COOKIES=https://your-server.com/cookies.txt
# Option 3: Use browser cookies (will use chrome by default)
# YOUTUBE_COOKIES=browser
YOUTUBE_COOKIES=

# Proxy Configuration (OPTIONAL)
# Comma-separated list of proxy URLs
# Supports: http, https, socks4, socks5
# Example: http://proxy1:8080,socks5://proxy2:1080,http://user:pass@proxy3:3128
PROXY_LIST=

# Rate Limiting Configuration
# Maximum number of retries for failed requests
MAX_RETRIES=3

# Base delay in milliseconds for exponential backoff
BASE_DELAY=1000

# Maximum delay in milliseconds
MAX_DELAY=30000

# =============================================================================
# ADVANCED CONFIGURATION
# =============================================================================

# User Agent for requests (OPTIONAL)
# Leave empty to use rotating user agents
USER_AGENT=

# Request timeout in milliseconds
REQUEST_TIMEOUT=15000

# Cache TTL in seconds (0 = no expiration)
CACHE_TTL=0

# Enable debug logging (true/false)
DEBUG_LOGGING=false

# =============================================================================
# EXTERNAL SERVICES (FUTURE ENHANCEMENTS)
# =============================================================================

# AssemblyAI API Key (for premium transcription)
# ASSEMBLYAI_API_KEY=your_assemblyai_key

# Rev.ai API Key (for premium transcription)
# REVAI_API_KEY=your_revai_key

# OpenAI API Key (for transcript enhancement)
# OPENAI_API_KEY=your_openai_key

# =============================================================================
# MONITORING AND ANALYTICS
# =============================================================================

# Enable performance monitoring
ENABLE_MONITORING=true

# Maximum number of errors to keep in memory
MAX_ERROR_HISTORY=100

# Statistics reset interval in hours (0 = manual reset only)
STATS_RESET_INTERVAL=0

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# CORS origins (comma-separated)
# Use * for development, specific domains for production
CORS_ORIGINS=*

# API rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# DEPLOYMENT SPECIFIC
# =============================================================================

# Railway specific (if deploying to Railway)
# RAILWAY_STATIC_URL=your-app.railway.app

# Vercel specific (if deploying to Vercel)
# VERCEL_URL=your-app.vercel.app

# Docker specific
# DOCKER_ENV=production

# =============================================================================
# NOTES
# =============================================================================

# 1. yt-dlp is now the PRIMARY transcript method - install it for best results
# 2. YOUTUBE_COOKIES significantly improves yt-dlp success rate
# 3. YOUTUBE_API_KEY serves as secondary fallback method
# 4. PROXY_LIST helps with rate limiting and geo-restrictions
# 5. Monitor /api/transcript-stats for performance insights
# 6. Use /api/transcript-performance for detailed analytics
# 7. All transcript features are backward compatible
# 8. Environment variables override default values
# 9. Restart server after changing environment variables
# 10. yt-dlp supports auto-generated and manual subtitles

# =============================================================================
# QUICK SETUP GUIDE
# =============================================================================

# Minimal setup (basic functionality):
# 1. Install yt-dlp: pip install yt-dlp
# 2. Copy this file to .env
# 3. Set PORT=3001
# 4. Start server

# Recommended setup (enhanced reliability):
# 1. Install yt-dlp: pip install yt-dlp (PRIMARY METHOD)
# 2. Export cookies from your browser to cookies.txt
# 3. Set YOUTUBE_COOKIES for enhanced access
# 4. Get YouTube Data API key as fallback
# 5. Monitor performance via /api/transcript-stats

# Production setup (maximum reliability):
# 1. Install yt-dlp binary or via pip
# 2. Configure YOUTUBE_COOKIES for optimal access
# 3. Set YouTube Data API key as backup
# 4. Configure proxy rotation if needed
# 5. Set up monitoring alerts
# 6. Configure rate limiting
# 7. Use specific CORS origins